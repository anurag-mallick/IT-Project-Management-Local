POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/horizon_it
DIRECT_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/horizon_it
JWT_SECRET=generate_a_random_64_char_string
NODE_ENV=production
NEXT_PUBLIC_LOCAL_MODE=true

# Email Configuration (SMTP - for Roundcube/Mail Server)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@yourdomain.com
SMTP_PASS=yourpassword
SMTP_FROM='IT Support <support@yourdomain.com>'

# Email Configuration (IMAP - for Incoming Tickets)
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USER=support@yourdomain.com
IMAP_PASS=yourpassword
IMAP_TICKET_FOLDER=INBOX
